  {
   "allow_on_submit": 1,
   "fieldname": "device_image_left",
   "fieldtype": "Attach Image",
   "label": "Left Side",
   "description": "Left side of the device"
  },
  {
   "fieldname": "column_break_evidence",
   "fieldtype": "Column Break"
  },
  {
   "allow_on_submit": 1,
   "fieldname": "device_image_right",
   "fieldtype": "Attach Image",
   "label": "Right Side",
   "description": "Right side of the device"
  },
  {
   "allow_on_submit": 1,
   "fieldname": "device_image_top",
   "fieldtype": "Attach Image",
   "label": "Top",
   "description": "Top view of the device"
  },
  {
   "allow_on_submit": 1,
   "fieldname": "device_image_bottom",
   "fieldtype": "Attach Image",
   "label": "Bottom",
   "description": "Bottom view of the device"
  },
  {
   "fieldname": "section_evidence_docs",
   "fieldtype": "Section Break",
   "label": "Supporting Documents"
  },
  {
   "fieldname": "supporting_documents",
   "fieldtype": "Attach",
   "label": "Supporting Documents",
   "description": "Purchase invoice, previous repair receipts, etc."
  },
  {
   "fieldname": "section_claim_media",
   "fieldtype": "Section Break",
   "label": "Claim Media",
   "collapsible": 1,
   "description": "Structured photos captured at each lifecycle stage"
  },
  {
   "fieldname": "claim_media",
   "fieldtype": "Table",
   "label": "Claim Media",
   "options": "CH Claim Media",
   "allow_on_submit": 1
  },
  {
   "fieldname": "section_processing_fee",
   "fieldtype": "Section Break",
   "label": "Processing Fee"
