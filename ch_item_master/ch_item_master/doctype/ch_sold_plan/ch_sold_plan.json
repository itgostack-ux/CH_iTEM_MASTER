   "title": "Active",
   "color": "Green"
  },
  {
   "title": "Expired",
   "color": "Grey"
  },
  {
   "title": "Claimed",
   "color": "Orange"
  },
  {
   "title": "Void",
   "color": "Red"
  },
  {
   "title": "Cancelled",
   "color": "Red"
  }
 ],
 "modified": "2026-02-28 00:00:00.000000",
 "creation": "2026-02-28 00:00:00.000000"
}