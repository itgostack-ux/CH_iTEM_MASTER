  {
   "fieldname": "column_break_processing_fee",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "processing_fee_invoice",
   "fieldtype": "Link",
   "label": "Processing Fee Invoice",
   "options": "Sales Invoice",
   "allow_on_submit": 1,
   "description": "Invoice for processing fee collection"
  },
  {
   "fieldname": "section_cost",
   "fieldtype": "Section Break",
   "label": "Cost Sharing"
