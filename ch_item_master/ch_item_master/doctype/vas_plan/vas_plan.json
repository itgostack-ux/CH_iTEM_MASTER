{
 "name": "VAS Plan",
 "module": "CH Item Master",
 "doctype": "DocType",
 "document_type": "Setup",
 "engine": "InnoDB",
 "autoname": "field:plan_name",
 "naming_rule": "By fieldname",
 "track_changes": 1,
 "title_field": "plan_name",
 "fields": [
  {"fieldname": "plan_name", "fieldtype": "Data", "label": "Plan Name", "reqd": 1, "in_list_view": 1, "unique": 1},
  {"fieldname": "vas_product", "fieldtype": "Link", "label": "VAS Product", "options": "VAS Product", "in_list_view": 1},
  {"fieldname": "source_warranty_plan", "fieldtype": "Link", "label": "Source CH Warranty Plan", "options": "CH Warranty Plan", "reqd": 1, "unique": 1, "in_standard_filter": 1},
  {"fieldname": "partner", "fieldtype": "Link", "label": "VAS Partner", "options": "VAS Partner"},
  {"fieldname": "column_break_1", "fieldtype": "Column Break"},
  {"fieldname": "duration_months", "fieldtype": "Int", "label": "Duration (Months)"},
  {"fieldname": "list_price", "fieldtype": "Currency", "label": "List Price"},
  {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Active\nInactive", "default": "Active", "in_list_view": 1},
  {"fieldname": "auto_attach", "fieldtype": "Check", "label": "Auto Attach", "default": "0"},
  {"fieldname": "attach_level", "fieldtype": "Select", "label": "Attach Level", "options": "Item\nBill\nOptional", "default": "Optional"},
  {"fieldname": "min_device_price", "fieldtype": "Currency", "label": "Min Device Price"},
  {"fieldname": "max_device_price", "fieldtype": "Currency", "label": "Max Device Price"},
  {"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "CH Warranty Manager", "read": 1, "write": 1, "create": 1},
  {"role": "POS Manager", "read": 1}
 ]
}
