 "fields": [
  {
   "fieldname": "naming_series",
   "fieldtype": "Select",
   "label": "Series",
   "options": "CH-WC-.YYYY.-",
   "default": "CH-WC-.YYYY.-",
   "reqd": 1,
   "hidden": 1
  },
  {
   "fieldname": "claim_id",
   "fieldtype": "Int",
   "label": "Claim ID",
   "read_only": 1,
   "unique": 1,
   "no_copy": 1
  },
  {
   "fieldname": "title",
   "fieldtype": "Data",
   "label": "Title",
   "read_only": 1,
   "hidden": 1
  },
  {
   "fieldname": "claim_date",
   "fieldtype": "Date",
   "label": "Claim Date",
   "default": "Today",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "company",
   "fieldtype": "Link",
   "label": "Company",
   "options": "Company",
   "reqd": 1,
   "in_standard_filter": 1,
   "remember_last_selected_value": 1,
   "description": "Company that sold the device (warranty issuer)"
  },
  {
   "fieldname": "reported_at_company",
   "fieldtype": "Link",
   "label": "Reported At (Company)",
   "options": "Company",
   "reqd": 1,
   "description": "Company where customer reported the issue (GoGizmo or GoFix)"
  },
  {
   "fieldname": "column_break_basic",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "claim_status",
   "fieldtype": "Select",
   "label": "Claim Status",
   "options": "Draft\nPending Coverage Check\nCoverage Identified\nPending Approval\nNeed More Information\nApproved\nPartially Approved\nRejected\nPickup Requested\nPickup Scheduled\nPicked Up\nDevice Received\nQC Pending\nQC Passed\nQC Failed\nFee Pending\nFee Paid\nFee Waived\nTicket Created\nIn Repair\nAdditional Approval Pending\nAwaiting Spare\nRepair Complete\nFinal QC Pending\nFinal QC Passed\nInvoice Pending\nInvoice Raised\nPayment Pending\nPayment Received\nOut for Delivery\nDelivered\nClosed\nCancelled\nNot Repairable",
   "default": "Draft",
   "in_list_view": 1,
   "in_standard_filter": 1,
   "read_only": 1,
   "no_copy": 1,
   "allow_on_submit": 1
  },
  {
   "fieldname": "coverage_type",
   "fieldtype": "Select",
   "label": "Coverage Type",
   "options": "anniversary_warranty\nvas_plan\nrepair_warranty\nmanufacturer_warranty\npaid_repair\ngoodwill",
   "in_list_view": 1,
   "in_standard_filter": 1,
   "read_only": 1,
   "no_copy": 1,
   "allow_on_submit": 1,
   "description": "Auto-determined from warranty status"
  },
  {
   "fieldname": "reported_by",
   "fieldtype": "Link",
   "label": "Reported By",
   "options": "User",
   "read_only": 1
  },
  {
   "fieldname": "reported_at_store",
   "fieldtype": "Data",
   "label": "Reported At Store",
   "description": "Store/location where claim was initiated"
  },
  {
   "fieldname": "section_device",
   "fieldtype": "Section Break",
   "label": "Device Information"
  },
  {
   "fieldname": "serial_no",
   "fieldtype": "Data",
   "label": "Serial / IMEI",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "imei_number",
   "fieldtype": "Data",
   "label": "IMEI Number",
   "read_only": 1,
   "description": "Auto-populated from CH Serial Lifecycle"
  },
  {
   "fieldname": "item_code",
   "fieldtype": "Link",
   "label": "Item",
   "options": "Item",
   "reqd": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "item_name",
   "fieldtype": "Data",
   "label": "Item Name",
   "fetch_from": "item_code.item_name",
   "read_only": 1
  },
  {
   "fieldname": "column_break_device",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "brand",
   "fieldtype": "Link",
   "label": "Brand",
   "options": "Brand",
   "fetch_from": "item_code.brand",
   "read_only": 1
  },
  {
   "fieldname": "customer",
   "fieldtype": "Link",
   "label": "Customer",
   "options": "Customer",
   "reqd": 1,
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "customer_name",
   "fieldtype": "Data",
   "label": "Customer Name",
   "fetch_from": "customer.customer_name",
   "read_only": 1
  },
  {
   "fieldname": "customer_phone",
   "fieldtype": "Data",
   "label": "Customer Phone",
   "options": "Phone",
   "description": "Auto-populated or manually entered",
   "fetch_from": "customer.mobile_no",
   "fetch_if_empty": 1
  },
  {
   "fieldname": "customer_email",
   "fieldtype": "Data",
   "label": "Customer Email",
   "options": "Email",
   "description": "Customer email for communication"
  },
  {
   "fieldname": "section_warranty",
   "fieldtype": "Section Break",
   "label": "Warranty Coverage"
  },
  {
   "fieldname": "sold_plan",
   "fieldtype": "Link",
   "label": "Covering Plan (Sold)",
   "options": "CH Sold Plan",
   "read_only": 1,
   "description": "Auto-populated from best active CH Sold Plan"
  },
  {
   "fieldname": "warranty_plan",
   "fieldtype": "Link",
   "label": "Warranty Plan",
   "options": "CH Warranty Plan",
   "read_only": 1,
   "description": "Auto-populated from the covering sold plan"
  },
  {
   "fieldname": "plan_type",
   "fieldtype": "Data",
   "label": "Plan Type",
   "read_only": 1,
   "description": "Own Warranty / Extended Warranty / VAS / Protection Plan"
  },
  {
   "fieldname": "warranty_status",
   "fieldtype": "Data",
   "label": "Warranty Status",
   "read_only": 1,
   "description": "Under Warranty / Out of Warranty / No Warranty"
  },
  {
   "fieldname": "column_break_warranty",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "warranty_start_date",
   "fieldtype": "Date",
   "label": "Warranty Start",
   "read_only": 1
  },
  {
   "fieldname": "warranty_end_date",
   "fieldtype": "Date",
   "label": "Warranty End",
   "read_only": 1
  },
  {
   "fieldname": "claims_used",
   "fieldtype": "Int",
   "label": "Claims Used",
   "read_only": 1
  },
  {
   "fieldname": "max_claims",
   "fieldtype": "Int",
   "label": "Max Claims",
   "read_only": 1
  },
  {
   "fieldname": "deductible_amount",
   "fieldtype": "Currency",
   "label": "Deductible Amount",
   "read_only": 1,
   "description": "Amount customer must pay per claim"
  },
  {
   "fieldname": "section_issue",
   "fieldtype": "Section Break",
   "label": "Issue Details"
  },
  {
   "fieldname": "issue_categories",
   "fieldtype": "Table MultiSelect",
   "label": "Issue Categories",
   "options": "CH Claim Issue Category",
   "description": "Select one or more issue categories"
  },
  {
   "fieldname": "issue_category",
   "fieldtype": "Link",
   "label": "Issue Category (legacy)",
   "options": "Issue Category",
   "hidden": 1,
   "description": "Legacy single issue category"
  },
  {
   "fieldname": "issue_description",
   "fieldtype": "Text",
   "label": "Issue Description",
   "reqd": 1,
   "description": "Describe the problem reported by the customer"
  },
  {
   "fieldname": "section_evidence",
   "fieldtype": "Section Break",
   "label": "Device Evidence"
  },
  {
   "allow_on_submit": 1,
   "fieldname": "device_image_front",
