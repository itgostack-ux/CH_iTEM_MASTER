{
 "name": "VAS Attach Rule",
 "module": "CH Item Master",
 "doctype": "DocType",
 "document_type": "Setup",
 "engine": "InnoDB",
 "autoname": "format:VAS-ATR-{####}",
 "naming_rule": "Expression",
 "track_changes": 1,
 "fields": [
  {"fieldname": "rule_name", "fieldtype": "Data", "label": "Rule Name", "reqd": 1, "in_list_view": 1},
  {"fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": "1", "in_list_view": 1},
  {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "Company"},
  {"fieldname": "vas_plan", "fieldtype": "Link", "label": "VAS Plan", "options": "VAS Plan", "reqd": 1, "in_list_view": 1},
  {"fieldname": "column_break_1", "fieldtype": "Column Break"},
  {"fieldname": "item_code", "fieldtype": "Link", "label": "Item", "options": "Item"},
  {"fieldname": "brand", "fieldtype": "Link", "label": "Brand", "options": "Brand"},
  {"fieldname": "category", "fieldtype": "Link", "label": "Category", "options": "CH Category"},
  {"fieldname": "sub_category", "fieldtype": "Link", "label": "Sub Category", "options": "CH Sub Category"},
  {"fieldname": "section_break_1", "fieldtype": "Section Break", "label": "Price Band"},
  {"fieldname": "min_price", "fieldtype": "Currency", "label": "Min Device Price"},
  {"fieldname": "max_price", "fieldtype": "Currency", "label": "Max Device Price"},
  {"fieldname": "column_break_2", "fieldtype": "Column Break"},
  {"fieldname": "auto_add", "fieldtype": "Check", "label": "Auto Add", "default": "0"},
  {"fieldname": "mandatory_offer", "fieldtype": "Check", "label": "Mandatory Offer", "default": "1"},
  {"fieldname": "priority", "fieldtype": "Int", "label": "Priority", "default": "0"},
  {"fieldname": "source_ch_attach_rule", "fieldtype": "Link", "label": "Source CH Attach Rule", "options": "CH Attach Rule", "in_standard_filter": 1},
  {"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "CH Warranty Manager", "read": 1, "write": 1, "create": 1},
  {"role": "Store Manager", "read": 1, "write": 1}
 ]
}
