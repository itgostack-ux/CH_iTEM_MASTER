  {
   "fieldname": "customer_share",
   "fieldtype": "Currency",
   "label": "Customer Pays",
   "description": "Deductible or out-of-warranty amount"
  },
  {
   "fieldname": "section_approval",
   "fieldtype": "Section Break",
   "label": "Approval",
   "depends_on": "eval:doc.requires_approval"
  },
  {
   "fieldname": "requires_approval",
   "fieldtype": "Check",
   "label": "Requires GoGizmo Approval",
   "read_only": 1,
   "description": "Set automatically when GoGizmo is paying"
  },
  {
   "fieldname": "approval_status",
   "fieldtype": "Select",
   "label": "Approval Status",
   "options": "Pending\nApproved\nPartially Approved\nRejected\nNeed More Information",
   "read_only": 1,
   "no_copy": 1,
   "in_standard_filter": 1,
   "allow_on_submit": 1
  },
  {
   "fieldname": "approved_amount",
   "fieldtype": "Currency",
   "label": "Approved Amount",
   "description": "GoGizmo approved amount (can be less than estimated cost for partial approval)",
   "read_only": 1,
   "allow_on_submit": 1,
   "depends_on": "eval:doc.approval_status=='Approved'"
