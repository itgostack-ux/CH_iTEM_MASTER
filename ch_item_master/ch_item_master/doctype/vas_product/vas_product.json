{
 "name": "VAS Product",
 "module": "CH Item Master",
 "doctype": "DocType",
 "document_type": "Setup",
 "engine": "InnoDB",
 "autoname": "field:product_name",
 "naming_rule": "By fieldname",
 "track_changes": 1,
 "title_field": "product_name",
 "fields": [
  {"fieldname": "product_name", "fieldtype": "Data", "label": "Product Name", "reqd": 1, "in_list_view": 1, "unique": 1},
  {"fieldname": "service_item", "fieldtype": "Link", "label": "Service Item", "options": "Item", "reqd": 1, "in_list_view": 1},
  {"fieldname": "product_type", "fieldtype": "Select", "label": "Product Type", "options": "Warranty\nValue Added Service\nProtection Plan\nInsurance\nEMI Add-on", "default": "Value Added Service", "in_list_view": 1},
  {"fieldname": "brand", "fieldtype": "Link", "label": "Brand", "options": "Brand"},
  {"fieldname": "category", "fieldtype": "Link", "label": "Category", "options": "CH Category"},
  {"fieldname": "column_break_1", "fieldtype": "Column Break"},
  {"fieldname": "min_price", "fieldtype": "Currency", "label": "Min Device Price"},
  {"fieldname": "max_price", "fieldtype": "Currency", "label": "Max Device Price"},
  {"fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": "1", "in_list_view": 1},
  {"fieldname": "source_warranty_plan", "fieldtype": "Link", "label": "Source CH Warranty Plan", "options": "CH Warranty Plan", "in_standard_filter": 1},
  {"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"}
 ],
 "permissions": [
  {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
  {"role": "CH Warranty Manager", "read": 1, "write": 1, "create": 1},
  {"role": "POS Manager", "read": 1}
 ]
}
